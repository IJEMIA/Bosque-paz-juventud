<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="theme-color" content="#2d5a2c">
    <title>El Bosque de la Paz Juventud</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="forest-container">
        <!-- Header con contador de árboles -->
        <header class="stats-header">
            <div class="tree-counter">
                <span class="tree-icon">🌳</span>
                <span id="totalTrees">0</span>
                <span class="tree-label">árboles sembrados</span>
            </div>
        </header>

        <!-- Mensaje de bienvenida simple -->
        <div class="welcome-message">
            <h2>🌲 El Bosque de la Paz 🌲</h2>
            <p>Elige un tiempo y siembra tu árbol</p>
        </div>

        <!-- Árbol en crecimiento -->
        <div class="growing-tree-area">
            <div class="tree-stage">
                <div class="tree-visual" id="treeVisual">🌱</div>
                <div class="progress-bar-container">
                    <div class="progress-bar" id="progressBar"></div>
                </div>
            </div>
        </div>

        <!-- Contador regresivo -->
        <div class="timer-container">
            <div class="timer-label">Tiempo restante</div>
            <div class="timer-display" id="timerDisplay">00:00:00</div>
        </div>

        <!-- Botones de tiempo -->
        <div class="time-selection" id="timeSelection">
            <button class="time-btn" data-hours="1">🌱 1 Hora</button>
            <button class="time-btn" data-hours="2">🌿 2 Horas</button>
            <button class="time-btn" data-hours="3">🌳 3 Horas</button>
            <button class="time-btn" data-hours="4">🌲 4 Horas</button>
        </div>

        <!-- Mensaje de estado -->
        <div class="status-message" id="statusMessage"></div>
    </div>

    <!-- Pantalla de bloqueo -->
    <div id="lockScreen" class="lock-screen">
        <div class="lock-content">
            <div class="lock-icon">🔒</div>
            <h2>Bosque Activo</h2>
            <p id="lockMessage">Tu árbol está creciendo. No salgas de esta pantalla.</p>
            <div class="lock-timer-mini" id="lockTimer">00:00:00</div>
            <div class="warning-text">⚠️ Si sales de esta pantalla, perderás tu progreso ⚠️</div>
        </div>
    </div>

    <!-- Modal de advertencia -->
    <div id="warningModal" class="modal">
        <div class="modal-content">
            <span class="close-modal">&times;</span>
            <h3>¡Atención!</h3>
            <p id="modalMessage">¿Estás seguro que quieres abandonar? Perderás tu árbol.</p>
            <button id="confirmAbandon" class="danger-btn">Sí, abandonar</button>
            <button id="cancelAbandon" class="safe-btn">Continuar</button>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
